---
import Layout from '@layouts/Layout.astro';
---

<Layout>
  <div x-data="paper">
    <h3 class="text-lg" x-text="paper.title"></h3>

    <div class="space-y-10">
      <div class="text-base-content/60 text-sm">
        <span x-text="paper.reference"></span>
        -
        <span x-text="paper.type"></span>
      </div>

      <div id="tabs" role="tablist" class="tabs tabs-lift">
        <input
          role="tab"
          class="tab"
          aria-label="Dokumente"
          type="radio"
          name="paper-tabs-radio"
          checked
        />
        <div class="tab-content border-base-200 bg-base-100 p-6">
          <div class="hidden md:block">
            <div class="flex flex-row md:space-x-2 lg:space-x-4">
              <div class="w-1/4">
                <ul class="menu bg-base-200 w-full -mx-2 space-y-1 rounded-box">
                  <template x-for="file in paper.files">
                    <li
                      @click="selectedFile !== file.id && selectFile(file.id)"
                    >
                      <div
                        class="flex flex-col items-start"
                        :class="{ 'menu-active': selectedFile === file.id }"
                      >
                        <span x-text="file.name"></span>
                        <span class="opacity-60" x-text="file.fileSizeDisplay"
                        ></span>
                      </div>
                    </li>
                  </template>
                </ul>
              </div>
              <div class="w-3/4">
                <iframe
                  x-show="fileSizeOk"
                  :src="documentUrl"
                  style="width: 100%; height: 90vh; border: 0"
                  loading="lazy"></iframe>

                <div x-show="!fileSizeOk" class="alert alert-soft alert-info">
                  <span class="iconify lucide--info size-5"></span>
                  <div class="flex flex-row items-center gap-2">
                    <p>Die Datei ist zu groß, um hier angezeigt zu werden.</p>
                    <a
                      class="btn btn-primary"
                      :href="documentUrl"
                      target="_blank"
                    >
                      PDF herunterladen <span x-text="fileSizeDisplay"></span>
                    </a>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <div class="md:hidden">
            <ul class="menu bg-base-200 w-full -mx-2 space-y-1 rounded-box">
              <template x-for="file in paper.files">
                <li @click="selectedFile !== file.id && selectFile(file.id)">
                  <a
                    class="flex flex-col items-start"
                    :href="file.url"
                    target="_blank"
                  >
                    <span x-text="file.name"></span>
                    <span class="opacity-60" x-text="file.fileSizeDisplay"
                    ></span>
                  </a>
                </li>
              </template>
            </ul>
          </div>
        </div>

        <input
          role="tab"
          class="tab"
          aria-label="Beratungen"
          type="radio"
          name="paper-tabs-radio"
        />
        <div class="tab-content border-base-200 bg-base-100 p-6">
          <ul class="timeline timeline-vertical">
            <template x-for="(consultation, index) in paper.consultations">
              <li>
                <hr x-show="index > 0" />
                <div class="timeline-start me-3 w-full text-right">
                  <span x-text="consultation.dateDisplay"></span>
                </div>
                <div class="timeline-middle">
                  <div
                    class="bg-base-200 grid place-items-center rounded-full border border-base-300 p-1"
                  >
                  </div>
                </div>
                <div
                  class="timeline-end timeline-box mt-5 ms-3 w-full space-y-2"
                >
                  <div class="text-base-content/70 space-x-1">
                    <span>TOP</span>
                    <span x-text="consultation.agendaItem"></span>
                  </div>
                  <div class="text-base" x-text="consultation.organization">
                  </div>
                  <div x-show="consultation.result">
                    <span
                      class="badge badge-neutral badge-sm"
                      x-text="consultation.result"></span>
                  </div>
                </div>
                <hr x-show="index < paper.consultations.length - 1" />
              </li>
            </template>
          </ul>
        </div>

        <input
          role="tab"
          class="tab"
          aria-label="Abstimmungen"
          type="radio"
          name="paper-tabs-radio"
        />
        <div class="tab-content border-base-200 bg-base-100 p-6">
          <div
            x-show="paper.votings.length === 0"
            class="alert alert-info alert-soft"
          >
            <span class="iconify lucide--info size-5"></span>
            Es liegen keine Abstimmungsdaten zu dieser Drucksache vor.
          </div>

          <ul
            x-show="paper.votings.length > 0"
            class="timeline timeline-vertical timeline-compact"
          >
            <template x-for="(voting, index) in paper.votings">
              <li>
                <hr x-show="index > 0" />
                <div class="timeline-middle">
                  <div
                    class="bg-base-200 grid place-items-center rounded-full border border-base-300 p-1"
                  >
                    <span
                      x-show="voting.accepted"
                      aria-label="angenommen"
                      class="iconify lucide--check text-success"></span>
                    <span
                      x-show="!voting.accepted"
                      aria-label="abgelehnt"
                      class="iconify lucide--x text-error"></span>
                  </div>
                </div>
                <a
                  :href="`/pp/${voting.parliamentPeriodId}/session/${voting.sessionId}/voting/${voting.votingId}`"
                  class="timeline-end timeline-box mt-5 ms-3 w-full space-y-2 hover:bg-base-200 hover:cursor-pointer"
                >
                  <div class="text-base-content/70 space-x-1">
                    <span x-text="voting.dateDisplay"></span>
                    <span>·</span>
                    <span x-text="voting.agendaItem"></span>
                    <span x-text="voting.type"></span>
                    <span x-text="voting.motionId"></span>
                  </div>
                  <div class="text-base" x-text="voting.title"></div>
                  <template x-if="voting.authors.length > 0">
                    <div class="flex flex-wrap gap-1">
                      <template x-for="author in voting.authors">
                        <span
                          class="badge badge-neutral badge-sm"
                          x-text="author"></span>
                      </template>
                    </div>
                  </template>
                  <div class="grid sm:grid-cols-[auto_1fr] sm:gap-x-2">
                    <template
                      x-for="votesByFaction in voting.votesByFactions"
                      :key="votesByFaction.factionId"
                    >
                      <template x-if="votesByFaction.votes.length > 0">
                        <div class="contents">
                          <div
                            class="text-base-content/70"
                            x-text="`${votesByFaction.factionName}:`"
                          >
                          </div>
                          <div class="mb-1 space-x-1">
                            <template x-for="vote in votesByFaction.votes">
                              <div class="tooltip" :data-tip="vote.personName">
                                <div
                                  class="status status-lg"
                                  :class="{ 'status-success': vote.vote === 'J', 'status-error': vote.vote === 'N', 'status-warning': vote.vote === 'E' }"
                                >
                                </div>
                              </div>
                            </template>
                          </div>
                        </div>
                      </template>
                    </template>
                  </div>
                </a>
                <hr x-show="index < paper.votings.length - 1" />
              </li>
            </template>
          </ul>
        </div>

        <input
          role="tab"
          class="tab"
          aria-label="Zugehörige Drucksachen"
          type="radio"
          name="paper-tabs-radio"
          x-bind:disabled="!paperTree || paperTree.children.length === 0"
        />
        <div class="tab-content border-base-200 bg-base-100 p-6">
          <template x-for="level in [paperTree]">
            <div class="space-y-4" x-html="renderLevel(level, 0)"></div>
          </template>
        </div>
      </div>
    </div>
  </div>
</Layout>

<script>
  import Alpine from 'alpinejs';
  import { AWS_CLOUDFRONT_BASE_URL } from 'astro:env/client';

  type PaperFile = {
    id: number;
    name: string;
    url: string;
    size: number | null;
  };

  type PaperConsultation = {
    meeting: string;
    date: string | null;
    role: string | null;
    organization: string;
    agendaItem: string | null;
    result: string | null;
  };

  type Vote = {
    personName: string;
    vote: string;
  };

  type VotesByFaction = {
    factionId: string;
    factionName: string;
    votes: Vote[];
  };

  type PaperVoting = {
    parliamentPeriodId: string;
    sessionId: string;
    votingId: number;
    date: string;
    agendaItem: string;
    motionId: string;
    title: string;
    type: string | null;
    authors: string[];
    accepted: boolean;
    votesByFactions: VotesByFaction[];
  };

  type Paper = {
    id: number;
    reference: string | null;
    type: string | null;
    title: string;
    files: PaperFile[];
    consultations: PaperConsultation[];
    votings: PaperVoting[];
    rootPaperId: number;
    subordinatedPaperIds: number[];
    superordinatedPaperIds: number[];
  };

  type PaperGraph = {
    rootPaperId: number;
    papers: Paper[];
  };

  type PaperTree = {
    paper: Paper;
    children: PaperTree[];
  };

  document.addEventListener('alpine:init', () => {
    Alpine.data('paper', () => ({
      renderLevel: function (paperNode: PaperTree | null, depth: number) {
        if (!paperNode) return '';

        let html = `
            <a
              href="/paper?paperId=${paperNode.paper.id}"
              class="card card-border bg-base-200 hover:bg-base-300"
              :class="{
                'border-base-300': paper.id !== ${paperNode.paper.id},
                'border-primary': paper.id === ${paperNode.paper.id},
              }"
              style="margin-left: ${depth * 2}rem;"
            >
              <div class="card-body">
                <div class="text-sm font-medium">
                  ${paperNode.paper.reference}
                  ${paperNode.paper.title}
                </div>
                <div class="text-base-content/70 mt-2 flex items-center text-xs">
                  ${paperNode.paper.type}
                </div>
              </div>
            </a>
        `;

        if (paperNode.children) {
          html += `
            <template x-for="level in level.children">
              <div
                class="space-y-4"
                x-html="renderLevel(level, ${depth + 1})"
              ></div>
            </template>
          `;
        }

        return html;
      },
      paper: {
        id: 0,
        reference: null,
        type: null,
        title: '',
        files: [],
        consultations: [],
        votings: [],
        rootPaperId: 0,
        subordinatedPaperIds: [],
        superordinatedPaperIds: [],
      } as Paper,
      paperTree: null as PaperTree | null,
      selectedFile: null as number | null,
      documentUrl: null as string | null,
      fileSizeOk: true,
      fileSizeDisplay: 'fileSizeDisplay',
      async init() {
        const queryParams = new URLSearchParams(location.search);
        const paperId = +(queryParams.get('paperId') || '0');

        const batchNo = `${Math.floor(paperId / 100)}`.padStart(4, '0');

        const batchResponse = await fetch(
          `${AWS_CLOUDFRONT_BASE_URL}/web-assets/papers/papers-${batchNo}.json`,
        );
        const batch = (await batchResponse.json()) as Paper[];
        const paper = batch.find((p) => p.id === paperId);

        if (!paper) {
          console.error(`Paper with id ${paperId} not found.`);
          return;
        }

        this.paper = {
          ...paper,
          files: paper.files.map((file) => ({
            ...file,
            fileSizeDisplay: `(${formatFileSize(file.size || 0)})`,
          })),
          consultations: paper.consultations.reverse().map((consultation) => ({
            ...consultation,
            dateDisplay: formatDate(consultation.date),
          })),
          votings: (paper.votings ?? []).map((voting) => ({
            ...voting,
            dateDisplay: formatDate(voting.date),
          })),
        };
        this.selectedFile = paper.files.length > 0 ? paper.files[0].id : null;
        this.documentUrl = paper.files.length > 0 ? paper.files[0].url : null;
        this.fileSizeOk =
          paper.files.length > 0 && (paper.files[0].size || 0) <= 1024 * 1024;
        this.fileSizeDisplay = formatFileSize(paper.files[0].size || 0);

        const paperGraphBatchNo =
          `${Math.floor(paper.rootPaperId / 100)}`.padStart(4, '0');

        const paperGraphBatchResponse = await fetch(
          `${AWS_CLOUDFRONT_BASE_URL}/web-assets/papers/paper-graphs-${paperGraphBatchNo}.json`,
        );
        const paperGraphBatch =
          (await paperGraphBatchResponse.json()) as PaperGraph[];
        const paperGraph = paperGraphBatch.find(
          (p) => p.rootPaperId === paper.rootPaperId,
        );

        if (!paperGraph) {
          console.error(
            `Paper graph with rootPaperId ${paper.rootPaperId} not found.`,
          );
          return;
        }

        this.paperTree = createPaperTree(paperGraph, paperGraph.rootPaperId);
      },
      selectFile: function (fileId: number) {
        if (fileId) {
          const file = this.paper.files.find((f) => f.id === fileId);
          if (file) {
            this.selectedFile = fileId;
            this.documentUrl = file.url;
            this.fileSizeOk = (file.size || 0) <= 1024 * 1024;
            this.fileSizeDisplay = `(${formatFileSize(file.size || 0)})`;
          }
        } else {
          this.selectedFile = null;
          this.documentUrl = null;
          this.fileSizeOk = true;
          this.fileSizeDisplay = '';
        }
      },
    }));
  });

  function formatFileSize(size: number) {
    const units = ['B', 'KB', 'MB', 'GB', 'TB'];
    let unitIndex = 0;
    let fileSize = size;
    while (fileSize >= 1024 && unitIndex < units.length) {
      fileSize /= 1024;
      unitIndex++;
    }

    return `${fileSize.toFixed(2)} ${units[unitIndex]}`;
  }

  function formatDate(dateString: string | null) {
    if (!dateString) return '';
    const date = new Date(dateString);
    return date.toLocaleDateString('de-DE', {
      day: '2-digit',
      month: '2-digit',
      year: 'numeric',
    });
  }

  function createPaperTree(paperGraph: PaperGraph, paperId: number): PaperTree {
    const paper = paperGraph.papers.find((p) => p.id === paperId)!;
    const children = paper.subordinatedPaperIds.map((subordinatedPaperId) =>
      createPaperTree(paperGraph, subordinatedPaperId),
    );
    return { paper, children };
  }
</script>
